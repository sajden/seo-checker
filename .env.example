GSC_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GSC_CLIENT_SECRET=your-oauth-client-secret
GSC_REDIRECT_URI=https://seo-api.sebcastwall.se/api/gsc/callback
